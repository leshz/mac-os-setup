# Navigation between splits
keybind = cmd+left=goto_split:left
keybind = cmd+right=goto_split:right
keybind = cmd+up=goto_split:up
keybind = cmd+down=goto_split:down
keybind = cmd+0=toggle_quick_terminal


# Custom configuration Mac os

# Theme

theme = "Emerald Synth"
font-size = 18
font-family = "Hack Nerd Font"
background-opacity = 0.8
background-blur-radius = 200


# Icon

macos-icon = holographic
macos-icon-frame = chrome

# Window

adw-toolbar-style = "flat"

# Custom

term = "xterm-256color"
shell-integration-features = no-cursor

# Animations
custom-shader = shaders/cursor_sweep.glsl
custom-shader = shaders/bloom.glsl
# custom-shader-animation = always
gtk-quick-terminal-layer = overlay
